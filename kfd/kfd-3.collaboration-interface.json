      "SECURITY.md",
      "TRADEMARK.md",
      "buildchain.alpha-contract-lock.json",
      "buildchain.contract-lock.json",
      "buildchain.toml",
      "docs/KUNGFU-GUI-CASK.md",
      "docs/MAP.md",
      "kfd/README.md",
      "kfd/kfd-1.contract-world.json",
      "kfd/kfd-1.witness.json",
      "kfd/kfd-2.release-claims.json",
      "kfd/kfd-3.collaboration-interface.json",
      "kfd/kfd-3.witness.json",
      "scripts/check-tap.mjs",
