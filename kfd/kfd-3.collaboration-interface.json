{
  "schemaVersion": 1,
  "contract": "kfd-3-collaboration-interface",
  "standard": "kfd-3",
  "product": {
    "name": "Kungfu Systems Homebrew Tap",
    "version": "repository-current",
    "repository": "kungfu-systems/homebrew-tap"
  },
  "sourceRegistry": {
    "path": "kfd/kfd-3.collaboration-interface.json"
  },
  "factSources": [
    {
      "id": "homebrew-tap-repository",
      "kind": "git-repository",
      "host": "github",
      "repository": "kungfu-systems/homebrew-tap",
      "url": "https://github.com/kungfu-systems/homebrew-tap",
      "loadBearingCoordinate": "commit-addressed repository contents",
      "canonicalPaths": [
        ".github/ISSUE_TEMPLATE/config.yml",
        ".github/pull_request_template.md",
        ".github/workflows/buildchain-validate.yml",
        ".github/workflows/managed-product-updates.yml",
        ".github/workflows/tap-check.yml",
        "ACCEPTABLE_USE.md",
        "AGENTS.md",
        "CONTRIBUTING.md",
        "Formula/buildchain.rb",
        "LICENSE",
        "PROVIDER_COMPLIANCE.md",
        "README.md",
        "SECURITY.md",
        "TRADEMARK.md",
        "buildchain.alpha-contract-lock.json",
        "buildchain.contract-lock.json",
        "buildchain.toml",
        "docs/KUNGFU-GUI-CASK.md",
        "docs/MAP.md",
